<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"></head>
<body style="font-family: Arial, sans-serif; background: #f4f4f4; padding: 20px; color: #333;">
  <div style="max-width: 600px; margin: 0 auto; background: #fff; padding: 20px; border-radius: 8px;">
    
    <h2 style="text-align: center; color: #2c3e50; margin-top: 0;">📊 VM Report: {{ timestamp }}</h2>
    
    <div style="background: #eef2f7; padding: 10px; border-radius: 4px; text-align: center; margin-bottom: 20px; font-size: 14px;">
      <strong>{{ collected_metrics | length }} VMs</strong> | 
      Avg CPU: {{ ((collected_metrics | map(attribute='cpu') | map('float') | sum) / (collected_metrics | length or 1)) | round(1) }}% | 
      Avg Mem: {{ ((collected_metrics | map(attribute='mem') | map('float') | sum) / (collected_metrics | length or 1)) | round(1) }}%
    </div>

    <table width="100%" cellpadding="8" cellspacing="0" style="border-collapse: collapse; font-size: 13px;">
      <thead>
        <tr style="background: #34495e; color: #fff;">
          <th align="left">Host</th>
          <th align="center">CPU</th>
          <th align="center">Mem</th>
          <th align="center">Disk</th>
        </tr>
      </thead>
      <tbody>
        {% for vm in collected_metrics %}
        <tr style="border-bottom: 1px solid #eee;">
          <td style="font-weight: bold;">{{ vm.hostname }}</td>
          
          <!-- CPU -->
          <td align="center">
            {{ vm.cpu }}%
            <div style="background: #ddd; height: 6px; border-radius: 3px; margin-top: 4px; width: 100px; display: inline-block;">
              <div style="background: {% if vm.cpu|float > 80 %}#e74c3c{% elif vm.cpu|float > 50 %}#f1c40f{% else %}#2ecc71{% endif %}; height: 100%; width: {{ vm.cpu }}%; border-radius: 3px;"></div>
            </div>
          </td>

          <!-- Mem -->
          <td align="center">
            {{ vm.mem }}%
            <div style="background: #ddd; height: 6px; border-radius: 3px; margin-top: 4px; width: 100px; display: inline-block;">
              <div style="background: {% if vm.mem|float > 80 %}#e74c3c{% elif vm.mem|float > 50 %}#f1c40f{% else %}#2ecc71{% endif %}; height: 100%; width: {{ vm.mem }}%; border-radius: 3px;"></div>
            </div>
          </td>

          <!-- Disk -->
          <td align="center">
            {{ vm.disk }}%
            <div style="background: #ddd; height: 6px; border-radius: 3px; margin-top: 4px; width: 100px; display: inline-block;">
              <div style="background: {% if vm.disk|float > 80 %}#e74c3c{% elif vm.disk|float > 50 %}#f1c40f{% else %}#2ecc71{% endif %}; height: 100%; width: {{ vm.disk }}%; border-radius: 3px;"></div>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    
    <div style="text-align: center; font-size: 11px; color: #999; margin-top: 20px;">
      Generated by Ansible
    </div>
  </div>
</body>
</html>    
